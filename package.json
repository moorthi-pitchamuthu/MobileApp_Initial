{
  "name": "mobile-app-starter",
  "version": "1.0.0",
  "description": "Generic Angular + Capacitor mobile app starter template (empty screens, reusable structure).",
  "scripts": {
    "ng": "node --max-old-space-size=4096 node_modules/@angular/cli/bin/ng.js",
    "start": "npm run ng -- serve",
    "dev": "npm run ng -- serve",
    "build": "npm run ng -- build",
    "build:prod": "npm run ng -- build --configuration production",
    "build:apk": "npm run build:prod && npx cap sync android",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android"
  },
  "dependencies": {
    "@angular/animations": "17.3.12",
    "@angular/common": "17.3.12",
    "@angular/compiler": "17.3.12",
    "@angular/core": "17.3.12",
    "@angular/fire": "^17.0.1",
    "@angular/forms": "17.3.12",
    "@angular/platform-browser": "17.3.12",
    "@angular/platform-browser-dynamic": "17.3.12",
    "@angular/router": "17.3.12",
    "@capacitor/app": "5.0.8",
    "@capacitor/core": "5.7.8",
    "@capacitor/splash-screen": "5.0.7",
    "@capacitor/status-bar": "5.0.7",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "firebase": "^10.7.2",
    "rxjs": "7.8.1",
    "tslib": "2.6.3",
    "zone.js": "0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "17.3.11",
    "@angular/cli": "17.3.11",
    "@angular/compiler-cli": "17.3.12",
    "@capacitor/android": "^5.7.8",
    "@capacitor/cli": "5.7.8",
    "typescript": "5.4.5"
  }
}
